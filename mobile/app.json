{
  "expo": {
    "name": "SalesManager AI",
    "slug": "salesmanager-ai",
    "scheme": "procureflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#131312"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.procureflow.salesmanager",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.335604282591-7paolmv2jm93g2lbn7g6gdrfo8jh3l0j"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#131312"
      },
      "package": "com.procureflow.salesmanager"
    },
    "extra": {
      "apiBaseUrl": "https://stockmanagerai.vercel.app",
      "eas": {
        "projectId": "b20b5d6e-1366-4aa3-8ee9-75b6cd735493"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "owner": "armaan.bawa25"
  }
}